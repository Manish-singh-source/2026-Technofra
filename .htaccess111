	 RewriteEngine on

RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ http://%1/$1 [R=301,L]

RewriteCond %{HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteEngine On
RewriteBase /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [NC,L]

# Enable mod_rewrite, necessary for URL rewriting
RewriteEngine On
#Redirect 301 /performance-marketing https://technofra.com/digital-marketing.php
#Redirect 301 /seo-services https://technofra.com/digital-marketing.php
#Redirect 301 /api-integration https://technofra.com/
#Redirect 301 /mobile-app-development https://technofra.com/android-app-development.php
#Redirect 301 /mobileapp https://technofra.com/android-app-development.php

#Redirect 301 /globalocean/contact https://technofra.com/
#Redirect 301 /e-commerce-website-design https://technofra.com/shopify-website-development.php
#Redirect 301 /mobile-app-development-indore https://technofra.com/android-app-development.php
 
#Redirect 301 /globalocean/tracking https://technofra.com/
RewriteCond %{HTTP_HOST} ^technofra\.com\.technofra\.co\.in$ [NC]
RewriteRule ^(.*)$ https://technofra.com/$1 [L,R=301]

# Custom 404 Error Document
ErrorDocument 404 /404.php

<Files 403.shtml>
order allow,deny
allow from all
</Files>
